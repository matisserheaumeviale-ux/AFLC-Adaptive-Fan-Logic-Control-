  46:Core/Src/LCD_UI.c **** const char* UI_GetAnimatedAction(FanAction_t action){
  47:Core/Src/LCD_UI.c ****     static const char *accel_frames[3] = {"+  ", "++ ", "+++"};
  48:Core/Src/LCD_UI.c ****     static const char *decel_frames[3] = {"---", " --", "  -"};
  49:Core/Src/LCD_UI.c **** 
  50:Core/Src/LCD_UI.c ****     switch(action){
  51:Core/Src/LCD_UI.c ****         case FAN_ACTION_ACCEL:
  52:Core/Src/LCD_UI.c ****             return accel_frames[g_ui_anim.tick % 3U];
  53:Core/Src/LCD_UI.c ****         case FAN_ACTION_DETECT:
  54:Core/Src/LCD_UI.c ****             return g_ui_anim.blink ? "@@@" : "   ";
  55:Core/Src/LCD_UI.c ****         case FAN_ACTION_DECEL:
  56:Core/Src/LCD_UI.c ****             return decel_frames[g_ui_anim.tick % 3U];
  57:Core/Src/LCD_UI.c ****         case FAN_ACTION_IDLE:
  58:Core/Src/LCD_UI.c ****             return g_ui_anim.blink ? "===" : "= =";
  59:Core/Src/LCD_UI.c ****         case FAN_ACTION_RAMP:
  60:Core/Src/LCD_UI.c ****             return g_ui_anim.blink ? "^^^" : " ^ ";
  61:Core/Src/LCD_UI.c ****         case FAN_ACTION_NONE:
  62:Core/Src/LCD_UI.c ****         default:
  63:Core/Src/LCD_UI.c ****             return "xxx";
  64:Core/Src/LCD_UI.c ****     }
  65:Core/Src/LCD_UI.c **** }
  66:Core/Src/LCD_UI.c **** 
  67:Core/Src/LCD_UI.c **** const char* UI_GetAnimatedAlert(FanAlert_t alert){
  68:Core/Src/LCD_UI.c ****     if(alert == FAN_ALERT_NONE){
  69:Core/Src/LCD_UI.c ****         return "   ";
  70:Core/Src/LCD_UI.c ****     }
  71:Core/Src/LCD_UI.c **** 
  72:Core/Src/LCD_UI.c ****     return g_ui_anim.blink ? "!!!" : "   ";
  73:Core/Src/LCD_UI.c **** }
