  15:Core/Src/LCD_UI.c **** const char* UI_FanStateToStr(FanState_t state){
  16:Core/Src/LCD_UI.c ****     switch(state){
  17:Core/Src/LCD_UI.c ****         case FAN_STATE_OFF:     return "Off ";
  18:Core/Src/LCD_UI.c ****         case FAN_STATE_STARTING:return "Strt";
  19:Core/Src/LCD_UI.c ****         case FAN_STATE_RUNNING: return "Run ";
  20:Core/Src/LCD_UI.c ****         case FAN_STATE_ERROR:   return "Err.";
  21:Core/Src/LCD_UI.c ****         default:                return "Err.";
  22:Core/Src/LCD_UI.c ****     }
  23:Core/Src/LCD_UI.c **** }
  24:Core/Src/LCD_UI.c **** 
  25:Core/Src/LCD_UI.c **** const char* UI_FanActionToStr(FanAction_t action){
  26:Core/Src/LCD_UI.c ****     switch(action){
  27:Core/Src/LCD_UI.c ****         case FAN_ACTION_ACCEL:    return "+++";
  28:Core/Src/LCD_UI.c ****         case FAN_ACTION_DETECT:   return "@@@";
  29:Core/Src/LCD_UI.c ****         case FAN_ACTION_DECEL:    return "---";
  30:Core/Src/LCD_UI.c ****         case FAN_ACTION_IDLE:     return "===";
  31:Core/Src/LCD_UI.c ****         case FAN_ACTION_RAMP:     return "^^^";
  32:Core/Src/LCD_UI.c ****         case FAN_ACTION_NONE:     return "xxx";
