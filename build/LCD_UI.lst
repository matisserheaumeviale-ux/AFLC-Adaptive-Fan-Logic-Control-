 108:Core/Src/LCD_UI.c **** static void UI_FormatFanLine(char out[21], uint8_t fan_index, const FanStatus_t *fan, uint8_t anima
 109:Core/Src/LCD_UI.c ****     const char *state;
 110:Core/Src/LCD_UI.c ****     const char *tail;
 111:Core/Src/LCD_UI.c ****     uint16_t rpm;
 112:Core/Src/LCD_UI.c ****     uint8_t percent;
 113:Core/Src/LCD_UI.c **** 
 114:Core/Src/LCD_UI.c ****     state = UI_FanStateToStr(fan->state);
 115:Core/Src/LCD_UI.c ****     rpm = (fan->rpm > 9999U) ? 9999U : fan->rpm;
 116:Core/Src/LCD_UI.c ****     percent = (fan->percent > 99U) ? 99U : fan->percent;
 117:Core/Src/LCD_UI.c **** 
 118:Core/Src/LCD_UI.c ****     if(fan->alert == FAN_ALERT_NONE){
 119:Core/Src/LCD_UI.c ****         tail = (animated != 0U) ? UI_GetAnimatedAction(fan->action) : UI_FanActionToStr(fan->action
 120:Core/Src/LCD_UI.c ****     } else {
 121:Core/Src/LCD_UI.c ****         tail = (animated != 0U) ? UI_GetAnimatedAlert(fan->alert) : UI_FanAlertToStr(fan->alert);
 122:Core/Src/LCD_UI.c ****     }
 123:Core/Src/LCD_UI.c **** 
 124:Core/Src/LCD_UI.c ****     (void)snprintf(out, 21, "F%1u %-4s%4u(%02u)%3s",
 125:Core/Src/LCD_UI.c ****                    (unsigned int)fan_index,
 126:Core/Src/LCD_UI.c ****                    state,
 127:Core/Src/LCD_UI.c ****                    (unsigned int)rpm,
 128:Core/Src/LCD_UI.c ****                    (unsigned int)percent,
 129:Core/Src/LCD_UI.c ****                    tail);
 130:Core/Src/LCD_UI.c **** }
