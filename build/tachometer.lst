   1:Core/Src/tachometer.c **** #include "tachometer.h"
   2:Core/Src/tachometer.c **** 
   3:Core/Src/tachometer.c **** // TIM2 capture les periodes des signaux tach.
   4:Core/Src/tachometer.c **** #define TACH_TIM_TICK_HZ            125000UL
   5:Core/Src/tachometer.c **** #define TACH_PULSES_PER_REVOLUTION  2UL
   6:Core/Src/tachometer.c **** #define TACH_TIMEOUT_MS             1200UL
   7:Core/Src/tachometer.c **** #define TACH_FILTER_SAMPLES         4U
   8:Core/Src/tachometer.c **** 
   9:Core/Src/tachometer.c **** // Etat d'un canal tachymetre.
  10:Core/Src/tachometer.c **** typedef struct {
  11:Core/Src/tachometer.c ****     volatile uint32_t last_capture;
  12:Core/Src/tachometer.c ****     volatile uint32_t period_ticks;
  13:Core/Src/tachometer.c ****     volatile uint32_t last_edge_ms;
  14:Core/Src/tachometer.c ****     volatile uint8_t first_capture;
  15:Core/Src/tachometer.c ****     volatile uint8_t pending_period;
  16:Core/Src/tachometer.c ****     uint16_t samples[TACH_FILTER_SAMPLES];
  17:Core/Src/tachometer.c ****     uint8_t sample_count;
  18:Core/Src/tachometer.c ****     uint8_t sample_index;
  19:Core/Src/tachometer.c ****     TachometerReading_t reading;
  20:Core/Src/tachometer.c **** } TachometerChannel_t;
  21:Core/Src/tachometer.c **** 
  22:Core/Src/tachometer.c **** static TachometerChannel_t g_tach[TACHOMETER_CHANNEL_COUNT];
  23:Core/Src/tachometer.c **** 
  24:Core/Src/tachometer.c **** static int32_t Tachometer_ChannelFromHal(const TIM_HandleTypeDef *htim);
  25:Core/Src/tachometer.c **** static void Tachometer_ResetSamples(TachometerChannel_t *channel);
  26:Core/Src/tachometer.c **** static uint16_t Tachometer_ComputeAverage(const TachometerChannel_t *channel);
  27:Core/Src/tachometer.c **** 
