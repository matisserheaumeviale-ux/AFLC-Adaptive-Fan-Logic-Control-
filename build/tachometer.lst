ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//cc4p3rkZ.s 			page 2


  33:Core/Src/tachometer.c ****     for (index = 0U; index < TACHOMETER_CHANNEL_COUNT; index++) {
  34:Core/Src/tachometer.c ****         g_tach[index].first_capture = 1U;
  35:Core/Src/tachometer.c ****         g_tach[index].pending_period = 0U;
  36:Core/Src/tachometer.c ****         Tachometer_ResetSamples(&g_tach[index]);
  37:Core/Src/tachometer.c ****         g_tach[index].reading.rpm_instant = 0U;
