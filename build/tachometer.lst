  39:Core/Src/tachometer.c ****         g_tach[index].reading.signal_present = false;
  40:Core/Src/tachometer.c ****         g_tach[index].reading.timeout = false;
  41:Core/Src/tachometer.c ****     }
  42:Core/Src/tachometer.c **** }
  43:Core/Src/tachometer.c **** 
  44:Core/Src/tachometer.c **** void Tachometer_OnCapture(TIM_HandleTypeDef *htim)
  45:Core/Src/tachometer.c **** {
  46:Core/Src/tachometer.c ****     int32_t channel_index;
  47:Core/Src/tachometer.c ****     TachometerChannel_t *channel;
  48:Core/Src/tachometer.c ****     uint32_t now_capture;
  49:Core/Src/tachometer.c ****     uint32_t period_ticks;
  50:Core/Src/tachometer.c ****     uint32_t tim_channel;
  51:Core/Src/tachometer.c **** 
  52:Core/Src/tachometer.c ****     if ((htim == NULL) || (htim->Instance != TIM2)) {
  53:Core/Src/tachometer.c ****         return;
  54:Core/Src/tachometer.c ****     }
  55:Core/Src/tachometer.c **** 
  56:Core/Src/tachometer.c ****     // On convertit le channel HAL en index 0..3.
  57:Core/Src/tachometer.c ****     channel_index = Tachometer_ChannelFromHal(htim);
  58:Core/Src/tachometer.c ****     if ((channel_index < 0) || (channel_index >= (int32_t)TACHOMETER_CHANNEL_COUNT)) {
  59:Core/Src/tachometer.c ****         return;
  60:Core/Src/tachometer.c ****     }
  61:Core/Src/tachometer.c **** 
  62:Core/Src/tachometer.c ****     channel = &g_tach[channel_index];
  63:Core/Src/tachometer.c ****     tim_channel = (uint32_t)(TIM_CHANNEL_1 + ((uint32_t)channel_index * 4UL));
  64:Core/Src/tachometer.c ****     now_capture = HAL_TIM_ReadCapturedValue(htim, tim_channel);
  65:Core/Src/tachometer.c **** 
  66:Core/Src/tachometer.c ****     // Premiere capture : on memorise seulement le point de depart.
  67:Core/Src/tachometer.c ****     if (channel->first_capture != 0U) {
  68:Core/Src/tachometer.c ****         channel->last_capture = now_capture;
  69:Core/Src/tachometer.c ****         channel->last_edge_ms = HAL_GetTick();
  70:Core/Src/tachometer.c ****         channel->first_capture = 0U;
  71:Core/Src/tachometer.c ****         channel->reading.signal_present = true;
  72:Core/Src/tachometer.c ****         channel->reading.timeout = false;
  73:Core/Src/tachometer.c ****         return;
  74:Core/Src/tachometer.c ****     }
  75:Core/Src/tachometer.c **** 
  76:Core/Src/tachometer.c ****     if (now_capture >= channel->last_capture) {
  77:Core/Src/tachometer.c ****         period_ticks = now_capture - channel->last_capture;
  78:Core/Src/tachometer.c ****     } else {
  79:Core/Src/tachometer.c ****         // Gestion du overflow 16 bits du timer.
  80:Core/Src/tachometer.c ****         period_ticks = (0xFFFFUL - channel->last_capture) + now_capture + 1UL;
  81:Core/Src/tachometer.c ****     }
  82:Core/Src/tachometer.c **** 
  83:Core/Src/tachometer.c ****     channel->last_capture = now_capture;
  84:Core/Src/tachometer.c ****     channel->last_edge_ms = HAL_GetTick();
  85:Core/Src/tachometer.c **** 
  86:Core/Src/tachometer.c ****     if (period_ticks > 0UL) {
  87:Core/Src/tachometer.c ****         channel->period_ticks = period_ticks;
  88:Core/Src/tachometer.c ****         channel->pending_period = 1U;
  89:Core/Src/tachometer.c ****     }
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//cc4p3rkZ.s 			page 3


  90:Core/Src/tachometer.c **** }
  91:Core/Src/tachometer.c **** 
  92:Core/Src/tachometer.c **** void Tachometer_Task(uint32_t now_ms)
  93:Core/Src/tachometer.c **** {
  94:Core/Src/tachometer.c ****     uint8_t index;
  95:Core/Src/tachometer.c **** 
  96:Core/Src/tachometer.c ****     for (index = 0U; index < TACHOMETER_CHANNEL_COUNT; index++) {
  97:Core/Src/tachometer.c ****         TachometerChannel_t *channel = &g_tach[index];
  98:Core/Src/tachometer.c **** 
  99:Core/Src/tachometer.c ****         if ((channel->first_capture == 0U) && ((now_ms - channel->last_edge_ms) > TACH_TIMEOUT_MS))
 100:Core/Src/tachometer.c ****             channel->reading.rpm_instant = 0U;
 101:Core/Src/tachometer.c ****             channel->reading.rpm_filtered = 0U;
 102:Core/Src/tachometer.c ****             channel->reading.signal_present = false;
 103:Core/Src/tachometer.c ****             channel->reading.timeout = true;
 104:Core/Src/tachometer.c ****             channel->pending_period = 0U;
 105:Core/Src/tachometer.c ****             Tachometer_ResetSamples(channel);
 106:Core/Src/tachometer.c ****             continue;
 107:Core/Src/tachometer.c ****         }
 108:Core/Src/tachometer.c **** 
 109:Core/Src/tachometer.c ****         // Une nouvelle periode a ete mesuree.
 110:Core/Src/tachometer.c ****         if (channel->pending_period != 0U) {
 111:Core/Src/tachometer.c ****             uint32_t rpm;
 112:Core/Src/tachometer.c **** 
 113:Core/Src/tachometer.c ****             channel->pending_period = 0U;
 114:Core/Src/tachometer.c **** 
 115:Core/Src/tachometer.c ****             // rpm = frequence * 60 / pulses_par_tour
 116:Core/Src/tachometer.c ****             rpm = ((TACH_TIM_TICK_HZ * 60UL) / channel->period_ticks) / TACH_PULSES_PER_REVOLUTION;
 117:Core/Src/tachometer.c ****             if (rpm > 65535UL) {
 118:Core/Src/tachometer.c ****                 rpm = 65535UL;
 119:Core/Src/tachometer.c ****             }
 120:Core/Src/tachometer.c **** 
 121:Core/Src/tachometer.c ****             channel->reading.rpm_instant = (uint16_t)rpm;
 122:Core/Src/tachometer.c ****             channel->samples[channel->sample_index] = (uint16_t)rpm;
 123:Core/Src/tachometer.c ****             channel->sample_index = (uint8_t)((channel->sample_index + 1U) % TACH_FILTER_SAMPLES);
 124:Core/Src/tachometer.c ****             if (channel->sample_count < TACH_FILTER_SAMPLES) {
 125:Core/Src/tachometer.c ****                 channel->sample_count++;
 126:Core/Src/tachometer.c ****             }
 127:Core/Src/tachometer.c **** 
 128:Core/Src/tachometer.c ****             // Petit filtre moyenne glissante.
 129:Core/Src/tachometer.c ****             channel->reading.rpm_filtered = Tachometer_ComputeAverage(channel);
 130:Core/Src/tachometer.c ****             channel->reading.signal_present = true;
 131:Core/Src/tachometer.c ****             channel->reading.timeout = false;
 132:Core/Src/tachometer.c ****         }
 133:Core/Src/tachometer.c ****     }
 134:Core/Src/tachometer.c **** }
 135:Core/Src/tachometer.c **** 
 136:Core/Src/tachometer.c **** const TachometerReading_t *Tachometer_GetReading(uint8_t index)
 137:Core/Src/tachometer.c **** {
