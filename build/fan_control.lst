 150:Core/Src/fan_control.c **** void FanControl_SetTargetRpm(uint8_t index, uint16_t target_rpm, uint16_t max_rpm)
 151:Core/Src/fan_control.c **** {
 152:Core/Src/fan_control.c ****     uint32_t duty_permille;
 153:Core/Src/fan_control.c **** 
 154:Core/Src/fan_control.c ****     if (index >= FAN_CONTROL_CHANNEL_COUNT) {
 155:Core/Src/fan_control.c ****         return;
 156:Core/Src/fan_control.c ****     }
 157:Core/Src/fan_control.c **** 
 158:Core/Src/fan_control.c ****     g_fans[index].status.target_rpm = target_rpm;
 159:Core/Src/fan_control.c **** 
 160:Core/Src/fan_control.c ****     if ((target_rpm == 0U) || (max_rpm == 0U)) {
 161:Core/Src/fan_control.c ****         FanControl_SetDutyPermille(index, 0U);
 162:Core/Src/fan_control.c ****         return;
 163:Core/Src/fan_control.c ****     }
 164:Core/Src/fan_control.c **** 
 165:Core/Src/fan_control.c ****     // Conversion simple RPM cible -> duty PWM.
 166:Core/Src/fan_control.c ****     duty_permille = ((uint32_t)target_rpm * 1000UL) / max_rpm;
 167:Core/Src/fan_control.c **** 
 168:Core/Src/fan_control.c ****     // On impose un plancher pratique.
 169:Core/Src/fan_control.c ****     // Trop bas et le fan ne demarre pas.
 170:Core/Src/fan_control.c ****     if (duty_permille < 150UL) {
 171:Core/Src/fan_control.c ****         duty_permille = 150UL;
 172:Core/Src/fan_control.c ****     }
 173:Core/Src/fan_control.c ****     if (duty_permille > 1000UL) {
 174:Core/Src/fan_control.c ****         duty_permille = 1000UL;
 175:Core/Src/fan_control.c ****     }
 176:Core/Src/fan_control.c **** 
 177:Core/Src/fan_control.c ****     FanControl_SetDutyPermille(index, (uint16_t)duty_permille);
 178:Core/Src/fan_control.c **** }
