 250:Core/Src/fan_control.c **** static void FanControl_ApplyDuty(FanChannel_t *fan)
 251:Core/Src/fan_control.c **** {
 252:Core/Src/fan_control.c ****     uint32_t compare;
 253:Core/Src/fan_control.c **** 
 254:Core/Src/fan_control.c ****     if ((fan == NULL) || (fan->htim_pwm == NULL) || (fan->pwm_port == NULL)) {
 255:Core/Src/fan_control.c ****         return;
 256:Core/Src/fan_control.c ****     }
 257:Core/Src/fan_control.c **** 
 258:Core/Src/fan_control.c ****     // Le signal PWM des ventilateurs 4-fils est interprete actif-bas.
 259:Core/Src/fan_control.c ****     // 0 % = ligne forcee haut, 100 % = ligne forcee bas.
 260:Core/Src/fan_control.c ****     if (fan->duty_permille == 0U) {
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//cca03sJx.s 			page 6


 261:Core/Src/fan_control.c ****         FanControl_SetPinAsOutput(fan, GPIO_PIN_SET);
 262:Core/Src/fan_control.c ****         return;
 263:Core/Src/fan_control.c ****     }
 264:Core/Src/fan_control.c **** 
 265:Core/Src/fan_control.c ****     if (fan->duty_permille >= FAN_DUTY_MAX_PERMILLE) {
 266:Core/Src/fan_control.c ****         FanControl_SetPinAsOutput(fan, GPIO_PIN_RESET);
 267:Core/Src/fan_control.c ****         return;
 268:Core/Src/fan_control.c ****     }
 269:Core/Src/fan_control.c **** 
 270:Core/Src/fan_control.c ****     FanControl_SetPinAsPwm(fan);
 271:Core/Src/fan_control.c **** 
 272:Core/Src/fan_control.c ****     // PWM1 actif-haut : on inverse le duty pour obtenir un temps bas
 273:Core/Src/fan_control.c ****     // proportionnel a la vitesse demandee.
 274:Core/Src/fan_control.c ****     compare = ((FAN_PWM_PERIOD + 1UL) * (FAN_DUTY_MAX_PERMILLE - fan->duty_permille)) / FAN_DUTY_MA
 275:Core/Src/fan_control.c ****     if (compare > FAN_PWM_PERIOD) {
 276:Core/Src/fan_control.c ****         compare = FAN_PWM_PERIOD;
 277:Core/Src/fan_control.c ****     }
 278:Core/Src/fan_control.c ****     __HAL_TIM_SET_COMPARE(fan->htim_pwm, fan->pwm_channel, compare);
 279:Core/Src/fan_control.c **** }
