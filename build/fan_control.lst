  50:Core/Src/fan_control.c ****         TIM_CHANNEL_4
  51:Core/Src/fan_control.c ****     };
  52:Core/Src/fan_control.c ****     static GPIO_TypeDef *const pwm_ports[FAN_CONTROL_CHANNEL_COUNT] = {
  53:Core/Src/fan_control.c ****         FAN1_PWM_GPIO_Port,
  54:Core/Src/fan_control.c ****         FAN2_PWM_GPIO_Port,
  55:Core/Src/fan_control.c ****         FAN3_PWM_GPIO_Port,
  56:Core/Src/fan_control.c ****         FAN4_PWM_GPIO_Port
  57:Core/Src/fan_control.c ****     };
  58:Core/Src/fan_control.c ****     static const uint16_t pwm_pins[FAN_CONTROL_CHANNEL_COUNT] = {
  59:Core/Src/fan_control.c ****         FAN1_PWM_Pin,
