  92:Core/Src/fan_control.c **** void FanControl_Task(uint32_t now_ms)
  93:Core/Src/fan_control.c **** {
  94:Core/Src/fan_control.c ****     uint8_t index;
  95:Core/Src/fan_control.c **** 
  96:Core/Src/fan_control.c ****     // Test de rampe progressif.
  97:Core/Src/fan_control.c ****     // Non bloquant. Avance par petits pas.
  98:Core/Src/fan_control.c ****     if (g_ramp.active && (now_ms >= g_ramp.next_step_ms)) {
  99:Core/Src/fan_control.c ****         FanControl_SetDutyPermilleAll(g_ramp.current_permille);
 100:Core/Src/fan_control.c ****         if (g_ramp.current_permille >= FAN_DUTY_MAX_PERMILLE) {
 101:Core/Src/fan_control.c ****             g_ramp.active = false;
 102:Core/Src/fan_control.c ****         } else {
 103:Core/Src/fan_control.c ****             g_ramp.current_permille = (uint16_t)(g_ramp.current_permille + FAN_RAMP_STEP_PERMILLE);
 104:Core/Src/fan_control.c ****             g_ramp.next_step_ms = now_ms + FAN_RAMP_STEP_MS;
 105:Core/Src/fan_control.c ****         }
 106:Core/Src/fan_control.c ****     }
 107:Core/Src/fan_control.c **** 
 108:Core/Src/fan_control.c ****     for (index = 0U; index < FAN_CONTROL_CHANNEL_COUNT; index++) {
 109:Core/Src/fan_control.c ****         FanControl_UpdateFan(&g_fans[index], index, now_ms);
 110:Core/Src/fan_control.c ****     }
 111:Core/Src/fan_control.c **** }
