 113:Core/Src/fan_control.c **** void FanControl_SetDutyPermille(uint8_t index, uint16_t duty_permille)
 114:Core/Src/fan_control.c **** {
 115:Core/Src/fan_control.c ****     if (index >= FAN_CONTROL_CHANNEL_COUNT) {
 116:Core/Src/fan_control.c ****         return;
 117:Core/Src/fan_control.c ****     }
 118:Core/Src/fan_control.c **** 
 119:Core/Src/fan_control.c ****     if (duty_permille > FAN_DUTY_MAX_PERMILLE) {
 120:Core/Src/fan_control.c ****         duty_permille = FAN_DUTY_MAX_PERMILLE;
 121:Core/Src/fan_control.c ****     }
 122:Core/Src/fan_control.c **** 
 123:Core/Src/fan_control.c ****     // Une nouvelle commande remet le chrono de demarrage.
 124:Core/Src/fan_control.c ****     g_fans[index].duty_permille = duty_permille;
 125:Core/Src/fan_control.c ****     g_fans[index].command_ms = HAL_GetTick();
 126:Core/Src/fan_control.c ****     if (duty_permille == 0U) {
 127:Core/Src/fan_control.c ****         g_fans[index].ever_detected = false;
 128:Core/Src/fan_control.c ****         g_fans[index].status.target_rpm = 0U;
 129:Core/Src/fan_control.c ****     }
 130:Core/Src/fan_control.c ****     FanControl_ApplyDuty(&g_fans[index]);
 131:Core/Src/fan_control.c **** }
 132:Core/Src/fan_control.c **** 
 133:Core/Src/fan_control.c **** void FanControl_SetDutyPermilleAll(uint16_t duty_permille)
 134:Core/Src/fan_control.c **** {
 135:Core/Src/fan_control.c ****     uint8_t index;
 136:Core/Src/fan_control.c **** 
 137:Core/Src/fan_control.c ****     if (duty_permille > FAN_DUTY_MAX_PERMILLE) {
 138:Core/Src/fan_control.c ****         duty_permille = FAN_DUTY_MAX_PERMILLE;
 139:Core/Src/fan_control.c ****     }
 140:Core/Src/fan_control.c **** 
 141:Core/Src/fan_control.c ****     if (g_ramp.active && (duty_permille != g_ramp.current_permille)) {
 142:Core/Src/fan_control.c ****         g_ramp.active = false;
 143:Core/Src/fan_control.c ****     }
 144:Core/Src/fan_control.c **** 
 145:Core/Src/fan_control.c ****     for (index = 0U; index < FAN_CONTROL_CHANNEL_COUNT; index++) {
 146:Core/Src/fan_control.c ****         FanControl_SetDutyPermille(index, duty_permille);
