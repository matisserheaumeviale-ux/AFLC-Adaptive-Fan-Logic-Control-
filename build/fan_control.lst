 281:Core/Src/fan_control.c **** static void FanControl_UpdateFan(FanChannel_t *fan, uint8_t index, uint32_t now_ms)
 282:Core/Src/fan_control.c **** {
 283:Core/Src/fan_control.c ****     const TachometerReading_t *tach;
 284:Core/Src/fan_control.c **** 
 285:Core/Src/fan_control.c ****     tach = Tachometer_GetReading(index);
 286:Core/Src/fan_control.c ****     if ((fan == NULL) || (tach == NULL)) {
 287:Core/Src/fan_control.c ****         return;
 288:Core/Src/fan_control.c ****     }
 289:Core/Src/fan_control.c **** 
 290:Core/Src/fan_control.c ****     fan->status.percent = FanControl_DutyToPercent(fan->duty_permille);
 291:Core/Src/fan_control.c ****     fan->status.rpm = tach->rpm_filtered;
 292:Core/Src/fan_control.c ****     fan->status.alert = FAN_ALERT_NONE;
 293:Core/Src/fan_control.c ****     fan->status.action = FAN_ACTION_IDLE;
 294:Core/Src/fan_control.c **** 
 295:Core/Src/fan_control.c ****     // Duty a zero = fan considere OFF.
 296:Core/Src/fan_control.c ****     if (fan->duty_permille == 0U) {
 297:Core/Src/fan_control.c ****         fan->status.state = FAN_STATE_OFF;
 298:Core/Src/fan_control.c ****         fan->status.action = FAN_ACTION_NONE;
 299:Core/Src/fan_control.c ****         fan->status.rpm = 0U;
 300:Core/Src/fan_control.c ****         fan->status.target_rpm = 0U;
 301:Core/Src/fan_control.c ****         fan->last_rpm = 0U;
 302:Core/Src/fan_control.c ****         return;
 303:Core/Src/fan_control.c ****     }
 304:Core/Src/fan_control.c **** 
 305:Core/Src/fan_control.c ****     // Cas normal : on voit un signal tach stable.
 306:Core/Src/fan_control.c ****     if (tach->signal_present && (tach->rpm_filtered >= FAN_RUNNING_MIN_RPM)) {
 307:Core/Src/fan_control.c ****         fan->status.state = FAN_STATE_RUNNING;
 308:Core/Src/fan_control.c ****         fan->ever_detected = true;
 309:Core/Src/fan_control.c **** 
 310:Core/Src/fan_control.c ****         // On determine la tendance pour l'affichage.
 311:Core/Src/fan_control.c ****         if (tach->rpm_filtered > (uint16_t)(fan->last_rpm + 50U)) {
 312:Core/Src/fan_control.c ****             fan->status.action = g_ramp.active ? FAN_ACTION_RAMP : FAN_ACTION_ACCEL;
 313:Core/Src/fan_control.c ****         } else if ((fan->last_rpm > 50U) && (tach->rpm_filtered + 50U < fan->last_rpm)) {
 314:Core/Src/fan_control.c ****             fan->status.action = FAN_ACTION_DECEL;
 315:Core/Src/fan_control.c ****         } else {
 316:Core/Src/fan_control.c ****             fan->status.action = FAN_ACTION_IDLE;
 317:Core/Src/fan_control.c ****         }
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//cca03sJx.s 			page 7


 318:Core/Src/fan_control.c ****     // Delai normal apres une commande PWM.
 319:Core/Src/fan_control.c ****     } else if ((now_ms - fan->command_ms) <= FAN_STARTUP_TIMEOUT_MS) {
 320:Core/Src/fan_control.c ****         fan->status.state = FAN_STATE_STARTING;
 321:Core/Src/fan_control.c ****         fan->status.action = FAN_ACTION_DETECT;
 322:Core/Src/fan_control.c ****     // Apres timeout, on declare une erreur.
 323:Core/Src/fan_control.c ****     } else {
 324:Core/Src/fan_control.c ****         fan->status.state = FAN_STATE_ERROR;
 325:Core/Src/fan_control.c ****         fan->status.action = FAN_ACTION_DETECT;
 326:Core/Src/fan_control.c ****         fan->status.alert = fan->ever_detected ? FAN_ALERT_FAULT : FAN_ALERT_WARN;
