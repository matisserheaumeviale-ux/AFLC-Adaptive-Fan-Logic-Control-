   7:Core/Src/LCD.c **** // Mapping physique des broches LCD sur GPIOB.
   8:Core/Src/LCD.c **** #define RS_Pin GPIO_PIN_9
   9:Core/Src/LCD.c **** #define RW_Pin GPIO_PIN_10
