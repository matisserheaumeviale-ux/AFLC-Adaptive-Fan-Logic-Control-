 149:Core/Src/ui_lcd.c **** static void UI_LCD_WriteLine(uint8_t row, const char *text)
 150:Core/Src/ui_lcd.c **** {
 151:Core/Src/ui_lcd.c ****     char fixed[21];
 152:Core/Src/ui_lcd.c ****     size_t len;
 153:Core/Src/ui_lcd.c **** 
 154:Core/Src/ui_lcd.c ****     if ((row > 3U) || (text == NULL)) {
 155:Core/Src/ui_lcd.c ****         return;
 156:Core/Src/ui_lcd.c ****     }
 157:Core/Src/ui_lcd.c **** 
 158:Core/Src/ui_lcd.c ****     // Le LCD est 20 colonnes.
 159:Core/Src/ui_lcd.c ****     // On tronque ou on remplit avec des espaces.
 160:Core/Src/ui_lcd.c ****     memset(fixed, ' ', 20U);
 161:Core/Src/ui_lcd.c ****     fixed[20] = '\0';
 162:Core/Src/ui_lcd.c ****     len = strlen(text);
 163:Core/Src/ui_lcd.c ****     if (len > 20U) {
 164:Core/Src/ui_lcd.c ****         len = 20U;
 165:Core/Src/ui_lcd.c ****     }
 166:Core/Src/ui_lcd.c ****     memcpy(fixed, text, len);
 167:Core/Src/ui_lcd.c **** 
 168:Core/Src/ui_lcd.c ****     if (strncmp(g_ui.cache[row], fixed, 20U) != 0) {
 169:Core/Src/ui_lcd.c ****         LCD_WriteAt(0, row, fixed);
 170:Core/Src/ui_lcd.c ****         memcpy(g_ui.cache[row], fixed, sizeof(fixed));
 171:Core/Src/ui_lcd.c ****     }
 172:Core/Src/ui_lcd.c **** }
 173:Core/Src/ui_lcd.c **** 
 174:Core/Src/ui_lcd.c **** static void UI_LCD_Render(void)
 175:Core/Src/ui_lcd.c **** {
 176:Core/Src/ui_lcd.c ****     // Routeur principal d'ecran.
 177:Core/Src/ui_lcd.c ****     switch (g_ui.screen) {
 178:Core/Src/ui_lcd.c ****         case UI_SCREEN_PROFILES_READY:
 179:Core/Src/ui_lcd.c ****             UI_LCD_RenderProfileScreen("Profiles Ready");
 180:Core/Src/ui_lcd.c ****             break;
 181:Core/Src/ui_lcd.c ****         case UI_SCREEN_WAIT_CONFIRM:
 182:Core/Src/ui_lcd.c ****             UI_LCD_RenderProfileScreen("Press 'c' UART");
 183:Core/Src/ui_lcd.c ****             break;
 184:Core/Src/ui_lcd.c ****         case UI_SCREEN_STARTUP_TEST:
 185:Core/Src/ui_lcd.c ****             UI_LCD_RenderStartupTest();
 186:Core/Src/ui_lcd.c ****             break;
 187:Core/Src/ui_lcd.c ****         case UI_SCREEN_RUNTIME:
 188:Core/Src/ui_lcd.c ****             UI_LCD_RenderRuntime();
 189:Core/Src/ui_lcd.c ****             break;
 190:Core/Src/ui_lcd.c ****         case UI_SCREEN_SAFE_STATE:
 191:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(0U, "Startup Failure");
 192:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(1U, "Safe State Active");
 193:Core/Src/ui_lcd.c ****             {
 194:Core/Src/ui_lcd.c ****                 char line[21];
 195:Core/Src/ui_lcd.c ****                 snprintf(line, sizeof(line), "Fail mask: 0x%02X", g_ui.fail_mask);
 196:Core/Src/ui_lcd.c ****                 UI_LCD_WriteLine(2U, line);
 197:Core/Src/ui_lcd.c ****             }
 198:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(3U, "Reset required");
 199:Core/Src/ui_lcd.c ****             break;
 200:Core/Src/ui_lcd.c ****         case UI_SCREEN_NONE:
 201:Core/Src/ui_lcd.c ****         default:
 202:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(0U, "AFLC Initializing");
 203:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(1U, "");
 204:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(2U, "");
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccjMeHU7.s 			page 5


 205:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(3U, "");
 206:Core/Src/ui_lcd.c ****             break;
 207:Core/Src/ui_lcd.c ****     }
 208:Core/Src/ui_lcd.c **** }
