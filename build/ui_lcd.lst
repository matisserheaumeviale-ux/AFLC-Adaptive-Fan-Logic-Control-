 278:Core/Src/ui_lcd.c **** static void UI_LCD_RenderRuntime(void)
 279:Core/Src/ui_lcd.c **** {
 280:Core/Src/ui_lcd.c ****     uint8_t page = UI_LCD_GetProfilePage();
 281:Core/Src/ui_lcd.c ****     uint8_t first_index = (uint8_t)(page * 2U);
 282:Core/Src/ui_lcd.c ****     uint8_t row;
 283:Core/Src/ui_lcd.c **** 
 284:Core/Src/ui_lcd.c ****     // Pour chaque fan :
 285:Core/Src/ui_lcd.c ****     // ligne 1/2 = RPM reel vs cible
 286:Core/Src/ui_lcd.c ****     // ligne 3/4 = temperature et duty
 287:Core/Src/ui_lcd.c ****     for (row = 0U; row < 2U; row++) {
 288:Core/Src/ui_lcd.c ****         char line[21];
 289:Core/Src/ui_lcd.c ****         uint8_t fan_index = (uint8_t)(first_index + row);
 290:Core/Src/ui_lcd.c **** 
 291:Core/Src/ui_lcd.c ****         if ((g_ui.profiles != NULL) && (g_ui.temps != NULL) && (g_ui.targets != NULL) && (g_ui.fans
 292:Core/Src/ui_lcd.c ****             snprintf(line,
 293:Core/Src/ui_lcd.c ****                      sizeof(line),
 294:Core/Src/ui_lcd.c ****                      "F%u %s %u/%u",
