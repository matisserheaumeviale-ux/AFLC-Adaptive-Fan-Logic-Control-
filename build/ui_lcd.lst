 329:Core/Src/ui_lcd.c **** static void UI_LCD_RenderFanDebug(void)
 330:Core/Src/ui_lcd.c **** {
 331:Core/Src/ui_lcd.c ****     uint8_t page = UI_LCD_GetProfilePage();
 332:Core/Src/ui_lcd.c ****     uint8_t first_index = (uint8_t)(page * 2U);
 333:Core/Src/ui_lcd.c ****     uint8_t row;
 334:Core/Src/ui_lcd.c **** 
 335:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(0U, "Fan Debug");
 336:Core/Src/ui_lcd.c **** 
 337:Core/Src/ui_lcd.c ****     for (row = 0U; row < 2U; row++) {
 338:Core/Src/ui_lcd.c ****         char line[21];
 339:Core/Src/ui_lcd.c ****         uint8_t fan_index = (uint8_t)(first_index + row);
 340:Core/Src/ui_lcd.c **** 
 341:Core/Src/ui_lcd.c ****         if ((g_ui.fans != NULL) && (fan_index < FAN_CONTROL_CHANNEL_COUNT)) {
 342:Core/Src/ui_lcd.c ****             snprintf(line,
 343:Core/Src/ui_lcd.c ****                      sizeof(line),
 344:Core/Src/ui_lcd.c ****                      "F%u %s P%3u T%4u",
 345:Core/Src/ui_lcd.c ****                      (unsigned int)(fan_index + 1U),
 346:Core/Src/ui_lcd.c ****                      UI_LCD_StateShort(g_ui.fans[fan_index].state),
 347:Core/Src/ui_lcd.c ****                      (unsigned int)g_ui.fans[fan_index].percent,
 348:Core/Src/ui_lcd.c ****                      (unsigned int)g_ui.fans[fan_index].rpm);
 349:Core/Src/ui_lcd.c ****         } else {
 350:Core/Src/ui_lcd.c ****             snprintf(line, sizeof(line), "F%u ----", (unsigned int)(fan_index + 1U));
 351:Core/Src/ui_lcd.c ****         }
 352:Core/Src/ui_lcd.c **** 
 353:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine((uint8_t)(row + 1U), line);
 354:Core/Src/ui_lcd.c ****     }
 355:Core/Src/ui_lcd.c **** 
 356:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(3U, page == 0U ? "F1/F2  ?=exit" : "F3/F4  ?=exit");
 357:Core/Src/ui_lcd.c **** }
