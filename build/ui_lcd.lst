  63:Core/Src/ui_lcd.c **** void UI_LCD_Task(uint32_t now_ms)
  64:Core/Src/ui_lcd.c **** {
  65:Core/Src/ui_lcd.c ****     // Si rien n'a change et qu'on est avant le prochain refresh, on sort.
  66:Core/Src/ui_lcd.c ****     if ((now_ms < g_ui.next_refresh_ms) && (g_ui.dirty == 0U)) {
  67:Core/Src/ui_lcd.c ****         return;
  68:Core/Src/ui_lcd.c ****     }
  69:Core/Src/ui_lcd.c **** 
  70:Core/Src/ui_lcd.c ****     // On alterne entre page 1 et page 2 pour afficher 4 fans sur 20x4.
  71:Core/Src/ui_lcd.c ****     if ((g_ui.screen == UI_SCREEN_PROFILES_READY) || (g_ui.screen == UI_SCREEN_WAIT_CONFIRM) || (g_
  72:Core/Src/ui_lcd.c ****         if ((now_ms - g_ui.page_started_ms) >= UI_LCD_PROFILE_PAGE_MS) {
  73:Core/Src/ui_lcd.c ****             g_ui.page_started_ms = now_ms;
  74:Core/Src/ui_lcd.c ****             g_ui.page_index ^= 1U;
  75:Core/Src/ui_lcd.c ****             g_ui.dirty = 1U;
  76:Core/Src/ui_lcd.c ****         }
  77:Core/Src/ui_lcd.c ****     }
  78:Core/Src/ui_lcd.c **** 
  79:Core/Src/ui_lcd.c ****     g_ui.next_refresh_ms = now_ms + UI_LCD_REFRESH_MS;
  80:Core/Src/ui_lcd.c ****     UI_LCD_Render();
  81:Core/Src/ui_lcd.c ****     g_ui.dirty = 0U;
  82:Core/Src/ui_lcd.c **** }
