 227:Core/Src/ui_lcd.c **** static void UI_LCD_RenderProfileScreen(const char *header)
 228:Core/Src/ui_lcd.c **** {
 229:Core/Src/ui_lcd.c ****     uint8_t page = UI_LCD_GetProfilePage();
 230:Core/Src/ui_lcd.c ****     uint8_t first_index = (uint8_t)(page * 2U);
 231:Core/Src/ui_lcd.c ****     uint8_t row;
 232:Core/Src/ui_lcd.c **** 
 233:Core/Src/ui_lcd.c ****     // Une page montre 2 ventilateurs.
 234:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(0U, header);
 235:Core/Src/ui_lcd.c **** 
 236:Core/Src/ui_lcd.c ****     for (row = 0U; row < 2U; row++) {
 237:Core/Src/ui_lcd.c ****         char line[21];
 238:Core/Src/ui_lcd.c ****         uint8_t fan_index = (uint8_t)(first_index + row);
 239:Core/Src/ui_lcd.c **** 
 240:Core/Src/ui_lcd.c ****         if ((g_ui.profiles != NULL) && (fan_index < PROFIL_FAN_COUNT)) {
 241:Core/Src/ui_lcd.c ****             snprintf(line,
 242:Core/Src/ui_lcd.c ****                      sizeof(line),
 243:Core/Src/ui_lcd.c ****                      "F%u %-6s %4ur",
 244:Core/Src/ui_lcd.c ****                      (unsigned int)(fan_index + 1U),
 245:Core/Src/ui_lcd.c ****                      Profil_GetName(g_ui.profiles->fans[fan_index].profile_id),
 246:Core/Src/ui_lcd.c ****                      (unsigned int)g_ui.profiles->fans[fan_index].nominal_rpm);
 247:Core/Src/ui_lcd.c ****         } else {
 248:Core/Src/ui_lcd.c ****             snprintf(line, sizeof(line), "F%u ----", (unsigned int)(fan_index + 1U));
 249:Core/Src/ui_lcd.c ****         }
 250:Core/Src/ui_lcd.c **** 
 251:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine((uint8_t)(row + 1U), line);
 252:Core/Src/ui_lcd.c ****     }
 253:Core/Src/ui_lcd.c **** 
 254:Core/Src/ui_lcd.c ****     if (g_ui.screen == UI_SCREEN_WAIT_CONFIRM) {
 255:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine(3U, "Waiting confirm...");
 256:Core/Src/ui_lcd.c ****     } else {
 257:Core/Src/ui_lcd.c ****         char footer[21];
 258:Core/Src/ui_lcd.c ****         snprintf(footer, sizeof(footer), "Page %u/2", (unsigned int)(page + 1U));
 259:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine(3U, footer);
 260:Core/Src/ui_lcd.c ****     }
 261:Core/Src/ui_lcd.c **** }
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//cc4osZ7R.s 			page 6


