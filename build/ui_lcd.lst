 263:Core/Src/ui_lcd.c **** static void UI_LCD_RenderStartupTest(void)
 264:Core/Src/ui_lcd.c **** {
 265:Core/Src/ui_lcd.c ****     uint8_t index;
 266:Core/Src/ui_lcd.c ****     char summary[21];
 267:Core/Src/ui_lcd.c **** 
 268:Core/Src/ui_lcd.c ****     // Deux premieres lignes : F1/F2.
 269:Core/Src/ui_lcd.c ****     // Derniere ligne : resume F3/F4.
 270:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(0U, g_ui.complete ? "Startup Test Done" : "Startup Test");
 271:Core/Src/ui_lcd.c **** 
 272:Core/Src/ui_lcd.c ****     for (index = 0U; index < 2U; index++) {
 273:Core/Src/ui_lcd.c ****         char line[21];
 274:Core/Src/ui_lcd.c ****         uint8_t fan_index = index;
 275:Core/Src/ui_lcd.c ****         char status = '-';
 276:Core/Src/ui_lcd.c **** 
 277:Core/Src/ui_lcd.c ****         if ((g_ui.fail_mask & (1U << fan_index)) != 0U) {
 278:Core/Src/ui_lcd.c ****             status = 'F';
 279:Core/Src/ui_lcd.c ****         } else if ((g_ui.passed_mask & (1U << fan_index)) != 0U) {
 280:Core/Src/ui_lcd.c ****             status = 'P';
 281:Core/Src/ui_lcd.c ****         }
 282:Core/Src/ui_lcd.c **** 
 283:Core/Src/ui_lcd.c ****         snprintf(line, sizeof(line), "Fan%u Tach [%c]", (unsigned int)(fan_index + 1U), status);
 284:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine((uint8_t)(index + 1U), line);
 285:Core/Src/ui_lcd.c ****     }
 286:Core/Src/ui_lcd.c **** 
 287:Core/Src/ui_lcd.c ****     snprintf(summary,
 288:Core/Src/ui_lcd.c ****              sizeof(summary),
 289:Core/Src/ui_lcd.c ****              "F3[%c] F4[%c]",
 290:Core/Src/ui_lcd.c ****              ((g_ui.fail_mask & (1U << 2U)) != 0U) ? 'F' : (((g_ui.passed_mask & (1U << 2U)) != 0U)
 291:Core/Src/ui_lcd.c ****              ((g_ui.fail_mask & (1U << 3U)) != 0U) ? 'F' : (((g_ui.passed_mask & (1U << 3U)) != 0U)
 292:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(3U, summary);
 293:Core/Src/ui_lcd.c **** }
 294:Core/Src/ui_lcd.c **** 
 295:Core/Src/ui_lcd.c **** static void UI_LCD_RenderRuntime(void)
 296:Core/Src/ui_lcd.c **** {
 297:Core/Src/ui_lcd.c ****     uint8_t page = UI_LCD_GetProfilePage();
