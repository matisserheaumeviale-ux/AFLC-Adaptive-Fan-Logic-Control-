 210:Core/Src/ui_lcd.c **** static void UI_LCD_RenderProfileScreen(const char *header)
 211:Core/Src/ui_lcd.c **** {
 212:Core/Src/ui_lcd.c ****     uint8_t page = UI_LCD_GetProfilePage();
 213:Core/Src/ui_lcd.c ****     uint8_t first_index = (uint8_t)(page * 2U);
 214:Core/Src/ui_lcd.c ****     uint8_t row;
 215:Core/Src/ui_lcd.c **** 
 216:Core/Src/ui_lcd.c ****     // Une page montre 2 ventilateurs.
 217:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(0U, header);
 218:Core/Src/ui_lcd.c **** 
 219:Core/Src/ui_lcd.c ****     for (row = 0U; row < 2U; row++) {
 220:Core/Src/ui_lcd.c ****         char line[21];
 221:Core/Src/ui_lcd.c ****         uint8_t fan_index = (uint8_t)(first_index + row);
 222:Core/Src/ui_lcd.c **** 
 223:Core/Src/ui_lcd.c ****         if ((g_ui.profiles != NULL) && (fan_index < PROFIL_FAN_COUNT)) {
 224:Core/Src/ui_lcd.c ****             snprintf(line,
 225:Core/Src/ui_lcd.c ****                      sizeof(line),
 226:Core/Src/ui_lcd.c ****                      "F%u %-6s %4ur",
 227:Core/Src/ui_lcd.c ****                      (unsigned int)(fan_index + 1U),
 228:Core/Src/ui_lcd.c ****                      Profil_GetName(g_ui.profiles->fans[fan_index].profile_id),
 229:Core/Src/ui_lcd.c ****                      (unsigned int)g_ui.profiles->fans[fan_index].nominal_rpm);
 230:Core/Src/ui_lcd.c ****         } else {
 231:Core/Src/ui_lcd.c ****             snprintf(line, sizeof(line), "F%u ----", (unsigned int)(fan_index + 1U));
 232:Core/Src/ui_lcd.c ****         }
 233:Core/Src/ui_lcd.c **** 
 234:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine((uint8_t)(row + 1U), line);
 235:Core/Src/ui_lcd.c ****     }
 236:Core/Src/ui_lcd.c **** 
 237:Core/Src/ui_lcd.c ****     if (g_ui.screen == UI_SCREEN_WAIT_CONFIRM) {
 238:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine(3U, "Waiting confirm...");
 239:Core/Src/ui_lcd.c ****     } else {
 240:Core/Src/ui_lcd.c ****         char footer[21];
 241:Core/Src/ui_lcd.c ****         snprintf(footer, sizeof(footer), "Page %u/2", (unsigned int)(page + 1U));
 242:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine(3U, footer);
 243:Core/Src/ui_lcd.c ****     }
 244:Core/Src/ui_lcd.c **** }
 245:Core/Src/ui_lcd.c **** 
 246:Core/Src/ui_lcd.c **** static void UI_LCD_RenderStartupTest(void)
 247:Core/Src/ui_lcd.c **** {
 248:Core/Src/ui_lcd.c ****     uint8_t index;
 249:Core/Src/ui_lcd.c ****     char summary[21];
 250:Core/Src/ui_lcd.c **** 
 251:Core/Src/ui_lcd.c ****     // Deux premieres lignes : F1/F2.
 252:Core/Src/ui_lcd.c ****     // Derniere ligne : resume F3/F4.
 253:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(0U, g_ui.complete ? "Startup Test Done" : "Startup Test");
 254:Core/Src/ui_lcd.c **** 
 255:Core/Src/ui_lcd.c ****     for (index = 0U; index < 2U; index++) {
 256:Core/Src/ui_lcd.c ****         char line[21];
 257:Core/Src/ui_lcd.c ****         uint8_t fan_index = index;
 258:Core/Src/ui_lcd.c ****         char status = '-';
 259:Core/Src/ui_lcd.c **** 
 260:Core/Src/ui_lcd.c ****         if ((g_ui.fail_mask & (1U << fan_index)) != 0U) {
 261:Core/Src/ui_lcd.c ****             status = 'F';
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccjMeHU7.s 			page 6


 262:Core/Src/ui_lcd.c ****         } else if ((g_ui.passed_mask & (1U << fan_index)) != 0U) {
 263:Core/Src/ui_lcd.c ****             status = 'P';
 264:Core/Src/ui_lcd.c ****         }
 265:Core/Src/ui_lcd.c **** 
 266:Core/Src/ui_lcd.c ****         snprintf(line, sizeof(line), "Fan%u Tach [%c]", (unsigned int)(fan_index + 1U), status);
 267:Core/Src/ui_lcd.c ****         UI_LCD_WriteLine((uint8_t)(index + 1U), line);
 268:Core/Src/ui_lcd.c ****     }
 269:Core/Src/ui_lcd.c **** 
 270:Core/Src/ui_lcd.c ****     snprintf(summary,
 271:Core/Src/ui_lcd.c ****              sizeof(summary),
 272:Core/Src/ui_lcd.c ****              "F3[%c] F4[%c]",
 273:Core/Src/ui_lcd.c ****              ((g_ui.fail_mask & (1U << 2U)) != 0U) ? 'F' : (((g_ui.passed_mask & (1U << 2U)) != 0U)
 274:Core/Src/ui_lcd.c ****              ((g_ui.fail_mask & (1U << 3U)) != 0U) ? 'F' : (((g_ui.passed_mask & (1U << 3U)) != 0U)
 275:Core/Src/ui_lcd.c ****     UI_LCD_WriteLine(3U, summary);
 276:Core/Src/ui_lcd.c **** }
