 139:Core/Src/ui_lcd.c **** static void UI_LCD_ClearCache(void)
 140:Core/Src/ui_lcd.c **** {
 141:Core/Src/ui_lcd.c ****     uint8_t row;
 142:Core/Src/ui_lcd.c **** 
 143:Core/Src/ui_lcd.c ****     // Le cache evite de reecrire la meme ligne.
 144:Core/Src/ui_lcd.c ****     for (row = 0U; row < 4U; row++) {
 145:Core/Src/ui_lcd.c ****         memset(g_ui.cache[row], 0, sizeof(g_ui.cache[row]));
 146:Core/Src/ui_lcd.c ****     }
 147:Core/Src/ui_lcd.c **** }
