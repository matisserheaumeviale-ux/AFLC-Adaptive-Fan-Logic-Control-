 151:Core/Src/ui_lcd.c **** static void UI_LCD_ClearCache(void)
 152:Core/Src/ui_lcd.c **** {
 153:Core/Src/ui_lcd.c ****     uint8_t row;
 154:Core/Src/ui_lcd.c **** 
 155:Core/Src/ui_lcd.c ****     // Le cache evite de reecrire la meme ligne.
 156:Core/Src/ui_lcd.c ****     for (row = 0U; row < 4U; row++) {
 157:Core/Src/ui_lcd.c ****         memset(g_ui.cache[row], 0, sizeof(g_ui.cache[row]));
 158:Core/Src/ui_lcd.c ****     }
 159:Core/Src/ui_lcd.c **** }
 160:Core/Src/ui_lcd.c **** 
 161:Core/Src/ui_lcd.c **** static void UI_LCD_WriteLine(uint8_t row, const char *text)
 162:Core/Src/ui_lcd.c **** {
 163:Core/Src/ui_lcd.c ****     char fixed[21];
 164:Core/Src/ui_lcd.c ****     size_t len;
 165:Core/Src/ui_lcd.c **** 
 166:Core/Src/ui_lcd.c ****     if ((row > 3U) || (text == NULL)) {
 167:Core/Src/ui_lcd.c ****         return;
 168:Core/Src/ui_lcd.c ****     }
 169:Core/Src/ui_lcd.c **** 
 170:Core/Src/ui_lcd.c ****     // Le LCD est 20 colonnes.
 171:Core/Src/ui_lcd.c ****     // On tronque ou on remplit avec des espaces.
 172:Core/Src/ui_lcd.c ****     memset(fixed, ' ', 20U);
 173:Core/Src/ui_lcd.c ****     fixed[20] = '\0';
 174:Core/Src/ui_lcd.c ****     len = strlen(text);
 175:Core/Src/ui_lcd.c ****     if (len > 20U) {
 176:Core/Src/ui_lcd.c ****         len = 20U;
 177:Core/Src/ui_lcd.c ****     }
 178:Core/Src/ui_lcd.c ****     memcpy(fixed, text, len);
 179:Core/Src/ui_lcd.c **** 
 180:Core/Src/ui_lcd.c ****     if (strncmp(g_ui.cache[row], fixed, 20U) != 0) {
 181:Core/Src/ui_lcd.c ****         LCD_WriteAt(0, row, fixed);
 182:Core/Src/ui_lcd.c ****         memcpy(g_ui.cache[row], fixed, sizeof(fixed));
 183:Core/Src/ui_lcd.c ****     }
 184:Core/Src/ui_lcd.c **** }
 185:Core/Src/ui_lcd.c **** 
 186:Core/Src/ui_lcd.c **** static void UI_LCD_Render(void)
 187:Core/Src/ui_lcd.c **** {
 188:Core/Src/ui_lcd.c ****     // Routeur principal d'ecran.
 189:Core/Src/ui_lcd.c ****     if (g_ui.debug_overlay != 0U) {
 190:Core/Src/ui_lcd.c ****         UI_LCD_RenderFanDebug();
 191:Core/Src/ui_lcd.c ****         return;
 192:Core/Src/ui_lcd.c ****     }
 193:Core/Src/ui_lcd.c **** 
 194:Core/Src/ui_lcd.c ****     switch (g_ui.screen) {
 195:Core/Src/ui_lcd.c ****         case UI_SCREEN_PROFILES_READY:
 196:Core/Src/ui_lcd.c ****             UI_LCD_RenderProfileScreen("Profiles Ready");
 197:Core/Src/ui_lcd.c ****             break;
 198:Core/Src/ui_lcd.c ****         case UI_SCREEN_WAIT_CONFIRM:
 199:Core/Src/ui_lcd.c ****             UI_LCD_RenderProfileScreen("Press 'c' UART");
 200:Core/Src/ui_lcd.c ****             break;
 201:Core/Src/ui_lcd.c ****         case UI_SCREEN_STARTUP_TEST:
 202:Core/Src/ui_lcd.c ****             UI_LCD_RenderStartupTest();
 203:Core/Src/ui_lcd.c ****             break;
 204:Core/Src/ui_lcd.c ****         case UI_SCREEN_RUNTIME:
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//cc4osZ7R.s 			page 5


 205:Core/Src/ui_lcd.c ****             UI_LCD_RenderRuntime();
 206:Core/Src/ui_lcd.c ****             break;
 207:Core/Src/ui_lcd.c ****         case UI_SCREEN_SAFE_STATE:
 208:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(0U, "Startup Failure");
 209:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(1U, "Safe State Active");
 210:Core/Src/ui_lcd.c ****             {
 211:Core/Src/ui_lcd.c ****                 char line[21];
 212:Core/Src/ui_lcd.c ****                 snprintf(line, sizeof(line), "Fail mask: 0x%02X", g_ui.fail_mask);
 213:Core/Src/ui_lcd.c ****                 UI_LCD_WriteLine(2U, line);
 214:Core/Src/ui_lcd.c ****             }
 215:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(3U, "Reset required");
 216:Core/Src/ui_lcd.c ****             break;
 217:Core/Src/ui_lcd.c ****         case UI_SCREEN_NONE:
 218:Core/Src/ui_lcd.c ****         default:
 219:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(0U, "AFLC Initializing");
 220:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(1U, "");
 221:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(2U, "");
 222:Core/Src/ui_lcd.c ****             UI_LCD_WriteLine(3U, "");
 223:Core/Src/ui_lcd.c ****             break;
 224:Core/Src/ui_lcd.c ****     }
 225:Core/Src/ui_lcd.c **** }
