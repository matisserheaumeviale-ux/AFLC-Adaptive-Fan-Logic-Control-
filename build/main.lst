 524:Core/Src/main.c **** static void AFLC_UpdateStartupPassMask(void)
 525:Core/Src/main.c **** {
 526:Core/Src/main.c ****   uint8_t index;
 527:Core/Src/main.c **** 
 528:Core/Src/main.c ****   Tachometer_GetSnapshot(&g_app.tach_snapshot);
 529:Core/Src/main.c **** 
 530:Core/Src/main.c ****   // Un bit par fan.
 531:Core/Src/main.c ****   // bit 0 -> fan 1, bit 1 -> fan 2, etc.
 532:Core/Src/main.c ****   for (index = 0U; index < PROFIL_FAN_COUNT; index++)
 533:Core/Src/main.c ****   {
 534:Core/Src/main.c ****     if (g_app.tach_snapshot.fans[index].rpm_filtered >= STARTUP_TEST_PASS_RPM)
 535:Core/Src/main.c ****     {
 536:Core/Src/main.c ****       g_app.startup_passed_mask |= (uint8_t)(1U << index);
 537:Core/Src/main.c ****     }
 538:Core/Src/main.c ****   }
 539:Core/Src/main.c **** }
