 357:Core/Src/main.c **** static void AFLC_AppTask(uint32_t now_ms)
 358:Core/Src/main.c **** {
 359:Core/Src/main.c ****   // Machine a etats principale.
 360:Core/Src/main.c ****   // Une seule source de verite pour le flux de demarrage.
 361:Core/Src/main.c ****   // Toute la progression de l'application passe ici.
 362:Core/Src/main.c ****   switch (g_app.state)
 363:Core/Src/main.c ****   {
 364:Core/Src/main.c ****     case AFLC_APP_BOOT:
 365:Core/Src/main.c ****       AFLC_AppEnterState(AFLC_APP_PROFILES_CALCULATING, now_ms);
 366:Core/Src/main.c ****       break;
 367:Core/Src/main.c **** 
 368:Core/Src/main.c ****     case AFLC_APP_PROFILES_CALCULATING:
 369:Core/Src/main.c ****       // On calcule les profils une seule fois.
 370:Core/Src/main.c ****       Profil_CalculateAll();
 371:Core/Src/main.c ****       g_app.profiles = Profil_GetResult();
 372:Core/Src/main.c ****       if ((g_app.profiles != NULL) && g_app.profiles->ready && g_app.profiles->valid)
 373:Core/Src/main.c ****       {
 374:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_PROFILES_READY, now_ms);
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccKX2YF8.s 			page 8


 375:Core/Src/main.c ****       }
 376:Core/Src/main.c ****       else
 377:Core/Src/main.c ****       {
 378:Core/Src/main.c ****         g_app.startup_fail_mask = 0x0FU;
 379:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_SAFE_STATE, now_ms);
 380:Core/Src/main.c ****       }
 381:Core/Src/main.c ****       break;
 382:Core/Src/main.c **** 
 383:Core/Src/main.c ****     case AFLC_APP_PROFILES_READY:
 384:Core/Src/main.c ****       // On laisse le temps de voir l'ecran.
 385:Core/Src/main.c ****       if ((now_ms - g_app.state_entered_ms) >= PROFILES_READY_SHOW_MS)
 386:Core/Src/main.c ****       {
 387:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_WAIT_CONFIRM, now_ms);
 388:Core/Src/main.c ****       }
 389:Core/Src/main.c ****       break;
 390:Core/Src/main.c **** 
 391:Core/Src/main.c ****     case AFLC_APP_WAIT_CONFIRM:
 392:Core/Src/main.c ****       // Le systeme attend un GO utilisateur.
 393:Core/Src/main.c ****       if (Button_IsConfirmPressed())
 394:Core/Src/main.c ****       {
 395:Core/Src/main.c ****         Button_ClearConfirm();
 396:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_INIT, now_ms);
 397:Core/Src/main.c ****       }
 398:Core/Src/main.c ****       break;
 399:Core/Src/main.c **** 
 400:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_INIT:
 401:Core/Src/main.c ****       // Test simple : on force un petit duty puis on observe les tachs.
 402:Core/Src/main.c ****       g_app.startup_passed_mask = 0U;
 403:Core/Src/main.c ****       g_app.startup_fail_mask = 0U;
 404:Core/Src/main.c ****       FanControl_SetDutyPermilleAll(STARTUP_TEST_DUTY_PERMILLE);
 405:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, g_app.startup_fail_mask, 0U);
 406:Core/Src/main.c ****       AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_RUN, now_ms);
 407:Core/Src/main.c ****       break;
 408:Core/Src/main.c **** 
 409:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_RUN:
 410:Core/Src/main.c ****       // Tant qu'on n'a pas vu les 4 fans, on continue.
 411:Core/Src/main.c ****       AFLC_UpdateStartupPassMask();
 412:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, 0U, 0U);
 413:Core/Src/main.c **** 
 414:Core/Src/main.c ****       if (g_app.startup_passed_mask == 0x0FU)
 415:Core/Src/main.c ****       {
 416:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_EVAL, now_ms);
 417:Core/Src/main.c ****       }
 418:Core/Src/main.c ****       else if ((now_ms - g_app.state_entered_ms) >= STARTUP_TEST_TIMEOUT_MS)
 419:Core/Src/main.c ****       {
 420:Core/Src/main.c ****         g_app.startup_fail_mask = (uint8_t)(0x0FU & (uint8_t)(~g_app.startup_passed_mask));
 421:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_EVAL, now_ms);
 422:Core/Src/main.c ****       }
 423:Core/Src/main.c ****       break;
 424:Core/Src/main.c **** 
 425:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_EVAL:
 426:Core/Src/main.c ****       // Si un fan manque, on bascule en safe state.
 427:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, g_app.startup_fail_mask, 1U);
 428:Core/Src/main.c ****       if (g_app.startup_fail_mask == 0U)
 429:Core/Src/main.c ****       {
 430:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_RUNTIME_CONTROL, now_ms);
 431:Core/Src/main.c ****       }
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccKX2YF8.s 			page 9


 432:Core/Src/main.c ****       else
 433:Core/Src/main.c ****       {
 434:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_SAFE_STATE, now_ms);
 435:Core/Src/main.c ****       }
 436:Core/Src/main.c ****       break;
 437:Core/Src/main.c **** 
 438:Core/Src/main.c ****     case AFLC_APP_RUNTIME_CONTROL:
 439:Core/Src/main.c ****       // En runtime, on rafraichit l'ecran avec les donnees courantes.
 440:Core/Src/main.c ****       UI_LCD_ShowRuntime(g_app.profiles,
 441:Core/Src/main.c ****                          g_app.temperatures,
 442:Core/Src/main.c ****                          &g_app.control_output,
 443:Core/Src/main.c ****                          FanControl_GetStatuses());
 444:Core/Src/main.c ****       break;
 445:Core/Src/main.c **** 
 446:Core/Src/main.c ****     case AFLC_APP_SAFE_STATE:
 447:Core/Src/main.c ****       // Etat de securite verrouille.
 448:Core/Src/main.c ****       FanControl_EnterSafeState();
 449:Core/Src/main.c ****       UI_LCD_ShowSafeState(g_app.startup_fail_mask);
 450:Core/Src/main.c ****       break;
 451:Core/Src/main.c **** 
 452:Core/Src/main.c ****     default:
 453:Core/Src/main.c ****       break;
 454:Core/Src/main.c ****   }
 455:Core/Src/main.c **** }
 456:Core/Src/main.c **** 
 457:Core/Src/main.c **** static void AFLC_AppEnterState(AflcAppState_t next_state, uint32_t now_ms)
 458:Core/Src/main.c **** {
 459:Core/Src/main.c ****   // Changement d'etat centralise.
 460:Core/Src/main.c ****   // Cela evite de disperser LEDs, LCD et timestamps un peu partout.
 461:Core/Src/main.c ****   g_app.state = next_state;
 462:Core/Src/main.c ****   g_app.state_entered_ms = now_ms;
 463:Core/Src/main.c **** 
 464:Core/Src/main.c ****   switch (next_state)
 465:Core/Src/main.c ****   {
 466:Core/Src/main.c ****     case AFLC_APP_BOOT:
 467:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_BOOT);
 468:Core/Src/main.c ****       break;
 469:Core/Src/main.c **** 
 470:Core/Src/main.c ****     case AFLC_APP_PROFILES_CALCULATING:
 471:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_BOOT);
 472:Core/Src/main.c ****       break;
 473:Core/Src/main.c **** 
 474:Core/Src/main.c ****     case AFLC_APP_PROFILES_READY:
 475:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_PROFILES_READY);
 476:Core/Src/main.c ****       UI_LCD_ShowProfilesReady(g_app.profiles);
 477:Core/Src/main.c ****       break;
 478:Core/Src/main.c **** 
 479:Core/Src/main.c ****     case AFLC_APP_WAIT_CONFIRM:
 480:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_WAIT_CONFIRM);
 481:Core/Src/main.c ****       UI_LCD_ShowWaitConfirm(g_app.profiles);
 482:Core/Src/main.c ****       break;
 483:Core/Src/main.c **** 
 484:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_INIT:
 485:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_RUN:
 486:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_EVAL:
 487:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_STARTUP_TEST);
 488:Core/Src/main.c ****       break;
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccKX2YF8.s 			page 10


 489:Core/Src/main.c **** 
 490:Core/Src/main.c ****     case AFLC_APP_RUNTIME_CONTROL:
 491:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_RUNTIME);
 492:Core/Src/main.c ****       break;
 493:Core/Src/main.c **** 
 494:Core/Src/main.c ****     case AFLC_APP_SAFE_STATE:
 495:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_FAULT);
 496:Core/Src/main.c ****       break;
 497:Core/Src/main.c **** 
 498:Core/Src/main.c ****     default:
 499:Core/Src/main.c ****       break;
 500:Core/Src/main.c ****   }
 501:Core/Src/main.c **** }
