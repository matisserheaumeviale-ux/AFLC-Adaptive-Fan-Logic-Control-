 503:Core/Src/main.c **** static void AFLC_RuntimeStep(void)
 504:Core/Src/main.c **** {
 505:Core/Src/main.c ****   uint16_t max_rpm[PROFIL_FAN_COUNT];
 506:Core/Src/main.c **** 
 507:Core/Src/main.c ****   // On ne regule qu'en vrai mode runtime.
 508:Core/Src/main.c ****   if ((g_app.state != AFLC_APP_RUNTIME_CONTROL) || (g_app.profiles == NULL) || (g_app.temperatures 
 509:Core/Src/main.c ****   {
 510:Core/Src/main.c ****     return;
 511:Core/Src/main.c ****   }
 512:Core/Src/main.c **** 
 513:Core/Src/main.c ****   Tachometer_GetSnapshot(&g_app.tach_snapshot);
 514:Core/Src/main.c **** 
 515:Core/Src/main.c ****   // 1. Lire le RPM reel
 516:Core/Src/main.c ****   // 2. Calculer la cible
 517:Core/Src/main.c ****   // 3. Convertir la cible en PWM
 518:Core/Src/main.c ****   // C'est la chaine principale de regulation.
 519:Core/Src/main.c ****   AFLCalcul_Compute(g_app.profiles, g_app.temperatures, &g_app.tach_snapshot, &g_app.control_output
 520:Core/Src/main.c ****   AFLC_BuildMaxRpmArray(max_rpm);
 521:Core/Src/main.c ****   FanControl_SetTargetRpmArray(g_app.control_output.target_rpm, max_rpm);
 522:Core/Src/main.c **** }
