 527:Core/Src/main.c **** static void AFLC_UpdateStartupPassMask(void)
 528:Core/Src/main.c **** {
 529:Core/Src/main.c ****   uint8_t index;
 530:Core/Src/main.c **** 
 531:Core/Src/main.c ****   Tachometer_GetSnapshot(&g_app.tach_snapshot);
 532:Core/Src/main.c **** 
 533:Core/Src/main.c ****   // Un bit par fan.
 534:Core/Src/main.c ****   // bit 0 -> fan 1, bit 1 -> fan 2, etc.
 535:Core/Src/main.c ****   for (index = 0U; index < PROFIL_FAN_COUNT; index++)
 536:Core/Src/main.c ****   {
 537:Core/Src/main.c ****     if (g_app.tach_snapshot.fans[index].rpm_filtered >= STARTUP_TEST_PASS_RPM)
 538:Core/Src/main.c ****     {
 539:Core/Src/main.c ****       g_app.startup_passed_mask |= (uint8_t)(1U << index);
 540:Core/Src/main.c ****     }
 541:Core/Src/main.c ****   }
 542:Core/Src/main.c **** }
