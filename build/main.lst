 390:Core/Src/main.c **** static void AFLC_AppEnterState(AflcAppState_t next_state, uint32_t now_ms)
 391:Core/Src/main.c **** {
 392:Core/Src/main.c ****   g_app.state = next_state;
 393:Core/Src/main.c ****   g_app.state_entered_ms = now_ms;
 394:Core/Src/main.c **** 
 395:Core/Src/main.c ****   switch (next_state)
 396:Core/Src/main.c ****   {
 397:Core/Src/main.c ****     case AFLC_APP_BOOT:
 398:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_BOOT);
 399:Core/Src/main.c ****       break;
 400:Core/Src/main.c **** 
 401:Core/Src/main.c ****     case AFLC_APP_PROFILES_CALCULATING:
 402:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_BOOT);
 403:Core/Src/main.c ****       break;
 404:Core/Src/main.c **** 
 405:Core/Src/main.c ****     case AFLC_APP_PROFILES_READY:
 406:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_PROFILES_READY);
 407:Core/Src/main.c ****       UI_LCD_ShowProfilesReady(g_app.profiles);
 408:Core/Src/main.c ****       break;
 409:Core/Src/main.c **** 
 410:Core/Src/main.c ****     case AFLC_APP_WAIT_CONFIRM:
 411:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_WAIT_CONFIRM);
 412:Core/Src/main.c ****       UI_LCD_ShowWaitConfirm(g_app.profiles);
 413:Core/Src/main.c ****       break;
 414:Core/Src/main.c **** 
 415:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_INIT:
 416:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_RUN:
 417:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_EVAL:
 418:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_STARTUP_TEST);
 419:Core/Src/main.c ****       break;
 420:Core/Src/main.c **** 
 421:Core/Src/main.c ****     case AFLC_APP_RUNTIME_CONTROL:
 422:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_RUNTIME);
 423:Core/Src/main.c ****       break;
 424:Core/Src/main.c **** 
 425:Core/Src/main.c ****     case AFLC_APP_SAFE_STATE:
 426:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_FAULT);
 427:Core/Src/main.c ****       break;
 428:Core/Src/main.c **** 
 429:Core/Src/main.c ****     default:
 430:Core/Src/main.c ****       break;
 431:Core/Src/main.c ****   }
