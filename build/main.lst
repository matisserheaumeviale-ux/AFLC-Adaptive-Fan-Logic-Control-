 460:Core/Src/main.c **** static void AFLC_AppEnterState(AflcAppState_t next_state, uint32_t now_ms)
 461:Core/Src/main.c **** {
 462:Core/Src/main.c ****   // Changement d'etat centralise.
 463:Core/Src/main.c ****   // Cela evite de disperser LEDs, LCD et timestamps un peu partout.
 464:Core/Src/main.c ****   g_app.state = next_state;
 465:Core/Src/main.c ****   g_app.state_entered_ms = now_ms;
 466:Core/Src/main.c **** 
 467:Core/Src/main.c ****   switch (next_state)
 468:Core/Src/main.c ****   {
 469:Core/Src/main.c ****     case AFLC_APP_BOOT:
 470:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_BOOT);
 471:Core/Src/main.c ****       break;
 472:Core/Src/main.c **** 
 473:Core/Src/main.c ****     case AFLC_APP_PROFILES_CALCULATING:
 474:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_BOOT);
 475:Core/Src/main.c ****       break;
 476:Core/Src/main.c **** 
 477:Core/Src/main.c ****     case AFLC_APP_PROFILES_READY:
 478:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_PROFILES_READY);
 479:Core/Src/main.c ****       UI_LCD_ShowProfilesReady(g_app.profiles);
 480:Core/Src/main.c ****       break;
 481:Core/Src/main.c **** 
 482:Core/Src/main.c ****     case AFLC_APP_WAIT_CONFIRM:
 483:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_WAIT_CONFIRM);
 484:Core/Src/main.c ****       UI_LCD_ShowWaitConfirm(g_app.profiles);
 485:Core/Src/main.c ****       break;
 486:Core/Src/main.c **** 
 487:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_INIT:
 488:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_RUN:
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccwaal0s.s 			page 10


 489:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_EVAL:
 490:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_STARTUP_TEST);
 491:Core/Src/main.c ****       break;
 492:Core/Src/main.c **** 
 493:Core/Src/main.c ****     case AFLC_APP_RUNTIME_CONTROL:
 494:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_RUNTIME);
 495:Core/Src/main.c ****       break;
 496:Core/Src/main.c **** 
 497:Core/Src/main.c ****     case AFLC_APP_SAFE_STATE:
 498:Core/Src/main.c ****       LedStatus_SetMode(LED_STATUS_MODE_FAULT);
 499:Core/Src/main.c ****       break;
 500:Core/Src/main.c **** 
 501:Core/Src/main.c ****     default:
 502:Core/Src/main.c ****       break;
 503:Core/Src/main.c ****   }
 504:Core/Src/main.c **** }
