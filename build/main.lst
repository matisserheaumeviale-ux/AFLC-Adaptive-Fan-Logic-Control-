 432:Core/Src/main.c ****       {
 433:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_RUNTIME_CONTROL, now_ms);
 434:Core/Src/main.c ****       }
 435:Core/Src/main.c ****       else
 436:Core/Src/main.c ****       {
 437:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_SAFE_STATE, now_ms);
 438:Core/Src/main.c ****       }
 439:Core/Src/main.c ****       break;
 440:Core/Src/main.c **** 
 441:Core/Src/main.c ****     case AFLC_APP_RUNTIME_CONTROL:
 442:Core/Src/main.c ****       // En runtime, on rafraichit l'ecran avec les donnees courantes.
 443:Core/Src/main.c ****       UI_LCD_ShowRuntime(g_app.profiles,
 444:Core/Src/main.c ****                          g_app.temperatures,
 445:Core/Src/main.c ****                          &g_app.control_output,
 446:Core/Src/main.c ****                          FanControl_GetStatuses());
 447:Core/Src/main.c ****       break;
 448:Core/Src/main.c **** 
 449:Core/Src/main.c ****     case AFLC_APP_SAFE_STATE:
 450:Core/Src/main.c ****       // Etat de securite verrouille.
 451:Core/Src/main.c ****       FanControl_EnterSafeState();
 452:Core/Src/main.c ****       UI_LCD_ShowSafeState(g_app.startup_fail_mask);
 453:Core/Src/main.c ****       break;
 454:Core/Src/main.c **** 
 455:Core/Src/main.c ****     default:
 456:Core/Src/main.c ****       break;
 457:Core/Src/main.c ****   }
 458:Core/Src/main.c **** }
