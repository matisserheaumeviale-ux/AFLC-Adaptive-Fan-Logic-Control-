 360:Core/Src/main.c **** static void AFLC_AppTask(uint32_t now_ms)
 361:Core/Src/main.c **** {
 362:Core/Src/main.c ****   // Machine a etats principale.
 363:Core/Src/main.c ****   // Une seule source de verite pour le flux de demarrage.
 364:Core/Src/main.c ****   // Toute la progression de l'application passe ici.
 365:Core/Src/main.c ****   switch (g_app.state)
 366:Core/Src/main.c ****   {
 367:Core/Src/main.c ****     case AFLC_APP_BOOT:
 368:Core/Src/main.c ****       AFLC_AppEnterState(AFLC_APP_PROFILES_CALCULATING, now_ms);
 369:Core/Src/main.c ****       break;
 370:Core/Src/main.c **** 
 371:Core/Src/main.c ****     case AFLC_APP_PROFILES_CALCULATING:
 372:Core/Src/main.c ****       // On calcule les profils une seule fois.
 373:Core/Src/main.c ****       Profil_CalculateAll();
 374:Core/Src/main.c ****       g_app.profiles = Profil_GetResult();
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccwaal0s.s 			page 8


 375:Core/Src/main.c ****       if ((g_app.profiles != NULL) && g_app.profiles->ready && g_app.profiles->valid)
 376:Core/Src/main.c ****       {
 377:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_PROFILES_READY, now_ms);
 378:Core/Src/main.c ****       }
 379:Core/Src/main.c ****       else
 380:Core/Src/main.c ****       {
 381:Core/Src/main.c ****         g_app.startup_fail_mask = 0x0FU;
 382:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_SAFE_STATE, now_ms);
 383:Core/Src/main.c ****       }
 384:Core/Src/main.c ****       break;
 385:Core/Src/main.c **** 
 386:Core/Src/main.c ****     case AFLC_APP_PROFILES_READY:
 387:Core/Src/main.c ****       // On laisse le temps de voir l'ecran.
 388:Core/Src/main.c ****       if ((now_ms - g_app.state_entered_ms) >= PROFILES_READY_SHOW_MS)
 389:Core/Src/main.c ****       {
 390:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_WAIT_CONFIRM, now_ms);
 391:Core/Src/main.c ****       }
 392:Core/Src/main.c ****       break;
 393:Core/Src/main.c **** 
 394:Core/Src/main.c ****     case AFLC_APP_WAIT_CONFIRM:
 395:Core/Src/main.c ****       // Le systeme attend un GO utilisateur.
 396:Core/Src/main.c ****       if (Button_IsConfirmPressed())
 397:Core/Src/main.c ****       {
 398:Core/Src/main.c ****         Button_ClearConfirm();
 399:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_INIT, now_ms);
 400:Core/Src/main.c ****       }
 401:Core/Src/main.c ****       break;
 402:Core/Src/main.c **** 
 403:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_INIT:
 404:Core/Src/main.c ****       // Test simple : on force un petit duty puis on observe les tachs.
 405:Core/Src/main.c ****       g_app.startup_passed_mask = 0U;
 406:Core/Src/main.c ****       g_app.startup_fail_mask = 0U;
 407:Core/Src/main.c ****       FanControl_SetDutyPermilleAll(STARTUP_TEST_DUTY_PERMILLE);
 408:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, g_app.startup_fail_mask, 0U);
 409:Core/Src/main.c ****       AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_RUN, now_ms);
 410:Core/Src/main.c ****       break;
 411:Core/Src/main.c **** 
 412:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_RUN:
 413:Core/Src/main.c ****       // Tant qu'on n'a pas vu les 4 fans, on continue.
 414:Core/Src/main.c ****       AFLC_UpdateStartupPassMask();
 415:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, 0U, 0U);
 416:Core/Src/main.c **** 
 417:Core/Src/main.c ****       if (g_app.startup_passed_mask == 0x0FU)
 418:Core/Src/main.c ****       {
 419:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_EVAL, now_ms);
 420:Core/Src/main.c ****       }
 421:Core/Src/main.c ****       else if ((now_ms - g_app.state_entered_ms) >= STARTUP_TEST_TIMEOUT_MS)
 422:Core/Src/main.c ****       {
 423:Core/Src/main.c ****         g_app.startup_fail_mask = (uint8_t)(0x0FU & (uint8_t)(~g_app.startup_passed_mask));
 424:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_EVAL, now_ms);
 425:Core/Src/main.c ****       }
 426:Core/Src/main.c ****       break;
 427:Core/Src/main.c **** 
 428:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_EVAL:
 429:Core/Src/main.c ****       // Si un fan manque, on bascule en safe state.
 430:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, g_app.startup_fail_mask, 1U);
 431:Core/Src/main.c ****       if (g_app.startup_fail_mask == 0U)
