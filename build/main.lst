 506:Core/Src/main.c **** static void AFLC_RuntimeStep(void)
 507:Core/Src/main.c **** {
 508:Core/Src/main.c ****   uint16_t max_rpm[PROFIL_FAN_COUNT];
 509:Core/Src/main.c **** 
 510:Core/Src/main.c ****   // On ne regule qu'en vrai mode runtime.
 511:Core/Src/main.c ****   if ((g_app.state != AFLC_APP_RUNTIME_CONTROL) || (g_app.profiles == NULL) || (g_app.temperatures 
 512:Core/Src/main.c ****   {
 513:Core/Src/main.c ****     return;
 514:Core/Src/main.c ****   }
 515:Core/Src/main.c **** 
 516:Core/Src/main.c ****   Tachometer_GetSnapshot(&g_app.tach_snapshot);
 517:Core/Src/main.c **** 
 518:Core/Src/main.c ****   // 1. Lire le RPM reel
 519:Core/Src/main.c ****   // 2. Calculer la cible
 520:Core/Src/main.c ****   // 3. Convertir la cible en PWM
 521:Core/Src/main.c ****   // C'est la chaine principale de regulation.
 522:Core/Src/main.c ****   AFLCalcul_Compute(g_app.profiles, g_app.temperatures, &g_app.tach_snapshot, &g_app.control_output
 523:Core/Src/main.c ****   AFLC_BuildMaxRpmArray(max_rpm);
 524:Core/Src/main.c ****   FanControl_SetTargetRpmArray(g_app.control_output.target_rpm, max_rpm);
 525:Core/Src/main.c **** }
