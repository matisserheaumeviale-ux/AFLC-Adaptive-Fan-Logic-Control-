 126:Core/Src/main.c **** static void BootTrace(const char *text)
 127:Core/Src/main.c **** {
 128:Core/Src/main.c ****   size_t len = 0U;
 129:Core/Src/main.c **** 
 130:Core/Src/main.c ****   if (text == NULL)
 131:Core/Src/main.c ****   {
 132:Core/Src/main.c ****     return;
 133:Core/Src/main.c ****   }
 134:Core/Src/main.c **** 
 135:Core/Src/main.c ****   while (text[len] != '\0')
 136:Core/Src/main.c ****   {
 137:Core/Src/main.c ****     len++;
 138:Core/Src/main.c ****   }
 139:Core/Src/main.c **** 
 140:Core/Src/main.c ****   // Helper volontairement simple pour tracer le boot sur l'UART.
