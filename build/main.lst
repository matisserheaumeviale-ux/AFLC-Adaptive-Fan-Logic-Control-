 301:Core/Src/main.c **** static void AFLC_AppTask(uint32_t now_ms)
 302:Core/Src/main.c **** {
 303:Core/Src/main.c ****   switch (g_app.state)
 304:Core/Src/main.c ****   {
 305:Core/Src/main.c ****     case AFLC_APP_BOOT:
 306:Core/Src/main.c ****       AFLC_AppEnterState(AFLC_APP_PROFILES_CALCULATING, now_ms);
 307:Core/Src/main.c ****       break;
 308:Core/Src/main.c **** 
 309:Core/Src/main.c ****     case AFLC_APP_PROFILES_CALCULATING:
 310:Core/Src/main.c ****       Profil_CalculateAll();
 311:Core/Src/main.c ****       g_app.profiles = Profil_GetResult();
 312:Core/Src/main.c ****       if ((g_app.profiles != NULL) && g_app.profiles->ready && g_app.profiles->valid)
 313:Core/Src/main.c ****       {
 314:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_PROFILES_READY, now_ms);
 315:Core/Src/main.c ****       }
 316:Core/Src/main.c ****       else
 317:Core/Src/main.c ****       {
ARM GAS  /var/folders/t9/y_chwk8j4cv2jjx6x9_h4twc0000gn/T//ccHsVdf0.s 			page 7


 318:Core/Src/main.c ****         g_app.startup_fail_mask = 0x0FU;
 319:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_SAFE_STATE, now_ms);
 320:Core/Src/main.c ****       }
 321:Core/Src/main.c ****       break;
 322:Core/Src/main.c **** 
 323:Core/Src/main.c ****     case AFLC_APP_PROFILES_READY:
 324:Core/Src/main.c ****       if ((now_ms - g_app.state_entered_ms) >= PROFILES_READY_SHOW_MS)
 325:Core/Src/main.c ****       {
 326:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_WAIT_CONFIRM, now_ms);
 327:Core/Src/main.c ****       }
 328:Core/Src/main.c ****       break;
 329:Core/Src/main.c **** 
 330:Core/Src/main.c ****     case AFLC_APP_WAIT_CONFIRM:
 331:Core/Src/main.c ****       if (Button_IsConfirmPressed())
 332:Core/Src/main.c ****       {
 333:Core/Src/main.c ****         Button_ClearConfirm();
 334:Core/Src/main.c ****         AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_INIT, now_ms);
 335:Core/Src/main.c ****       }
 336:Core/Src/main.c ****       break;
 337:Core/Src/main.c **** 
 338:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_INIT:
 339:Core/Src/main.c ****       g_app.startup_passed_mask = 0U;
 340:Core/Src/main.c ****       g_app.startup_fail_mask = 0U;
 341:Core/Src/main.c ****       FanControl_SetDutyPermilleAll(STARTUP_TEST_DUTY_PERMILLE);
 342:Core/Src/main.c ****       UI_LCD_ShowStartupTest(g_app.startup_passed_mask, g_app.startup_fail_mask, 0U);
 343:Core/Src/main.c ****       AFLC_AppEnterState(AFLC_APP_STARTUP_TEST_RUN, now_ms);
 344:Core/Src/main.c ****       break;
 345:Core/Src/main.c **** 
 346:Core/Src/main.c ****     case AFLC_APP_STARTUP_TEST_RUN:
