  40:Core/Src/led_status.c **** void LedStatus_Task(uint32_t now_ms)
  41:Core/Src/led_status.c **** {
  42:Core/Src/led_status.c ****     bool led_status_on = false;
  43:Core/Src/led_status.c ****     bool led_error_on = false;
  44:Core/Src/led_status.c ****     bool led_extra_on = false;
  45:Core/Src/led_status.c **** 
  46:Core/Src/led_status.c ****     if ((now_ms - g_leds.heartbeat_ms) >= LED_HEARTBEAT_PERIOD_MS) {
  47:Core/Src/led_status.c ****         g_leds.heartbeat_ms = now_ms;
  48:Core/Src/led_status.c ****         g_leds.heartbeat_on = !g_leds.heartbeat_on;
  49:Core/Src/led_status.c ****     }
  50:Core/Src/led_status.c **** 
  51:Core/Src/led_status.c ****     // Chaque mode traduit un etat applicatif.
  52:Core/Src/led_status.c ****     switch (g_leds.mode) {
  53:Core/Src/led_status.c ****         case LED_STATUS_MODE_BOOT:
  54:Core/Src/led_status.c ****             led_status_on = true;
  55:Core/Src/led_status.c ****             break;
  56:Core/Src/led_status.c ****         case LED_STATUS_MODE_PROFILES_READY:
  57:Core/Src/led_status.c ****             led_status_on = true;
  58:Core/Src/led_status.c ****             led_extra_on = true;
  59:Core/Src/led_status.c ****             break;
  60:Core/Src/led_status.c ****         case LED_STATUS_MODE_WAIT_CONFIRM:
  61:Core/Src/led_status.c ****             led_status_on = g_leds.heartbeat_on;
  62:Core/Src/led_status.c ****             break;
  63:Core/Src/led_status.c ****         case LED_STATUS_MODE_STARTUP_TEST:
  64:Core/Src/led_status.c ****             led_status_on = true;
  65:Core/Src/led_status.c ****             led_extra_on = g_leds.heartbeat_on;
  66:Core/Src/led_status.c ****             break;
  67:Core/Src/led_status.c ****         case LED_STATUS_MODE_RUNTIME:
  68:Core/Src/led_status.c ****             led_status_on = g_leds.heartbeat_on;
  69:Core/Src/led_status.c ****             break;
  70:Core/Src/led_status.c ****         case LED_STATUS_MODE_FAULT:
  71:Core/Src/led_status.c ****         default:
  72:Core/Src/led_status.c ****             led_error_on = true;
  73:Core/Src/led_status.c ****             break;
  74:Core/Src/led_status.c ****     }
