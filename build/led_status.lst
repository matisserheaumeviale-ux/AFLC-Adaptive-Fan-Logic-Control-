  77:Core/Src/led_status.c ****                     LED_USB_Pin,
  78:Core/Src/led_status.c ****                     (now_ms - g_leds.comm_activity_ms) <= LED_ACTIVITY_HOLD_MS);
  79:Core/Src/led_status.c ****     LedStatus_Write(LED_STATUS_GPIO_Port, LED_STATUS_Pin, led_status_on);
  80:Core/Src/led_status.c ****     LedStatus_Write(LED_ERROR_GPIO_Port, LED_ERROR_Pin, led_error_on);
  81:Core/Src/led_status.c ****     LedStatus_Write(LED_EXTRA1_GPIO_Port, LED_EXTRA1_Pin, led_extra_on);
